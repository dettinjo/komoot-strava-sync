# ── Komoot credentials ──────────────────────────────────────────────────────
# Your Komoot account email and password (used for Basic Auth)
KOMOOT_EMAIL=your@email.com
KOMOOT_PASSWORD=yourpassword

# Your Komoot numeric user ID (found in your profile URL:
#   https://www.komoot.com/user/123456789  →  KOMOOT_USER_ID=123456789)
KOMOOT_USER_ID=123456789

# ── Strava API app (create at https://www.strava.com/settings/api) ──────────
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=abcdef0123456789abcdef0123456789abcdef01

# ── Strava OAuth tokens (run  python scripts/get_token.py  to obtain) ───────
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=

# ── Sync behaviour ───────────────────────────────────────────────────────────
# How often to check for new Komoot activities (minutes, default 30)
SYNC_INTERVAL_MINUTES=30

# On first run, how many days back to sync (default 30)
INITIAL_SYNC_DAYS=30
